# RhoDyn Stage 4 backend deployment example.
#
# Copy values into your process manager or container environment. The store path
# should point at a persistent volume if jobs must survive restarts.

RHODYN_JOB_STORE_DIR=.rhodyn_jobs

# Optional retention limits. Leave blank or unset for no automatic pruning.
RHODYN_JOB_RETENTION_MAX_JOBS=500
RHODYN_JOB_RETENTION_MAX_BYTES=1073741824
RHODYN_JOB_RETENTION_MAX_AGE_SECONDS=604800

# Example command:
# uvicorn rhodyn.backend:app --host 0.0.0.0 --port 8000
